# ECCRP Backend Environment Configuration
# Copy this to .env and fill in your values

# ── Application ────────────────────────────────────────────────────────────
APP_NAME=ECCRP
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change_me_to_a_random_64_char_string
API_V1_STR=/api/v1

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://eccrp:eccrp_secret@localhost:5432/eccrp
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40
DATABASE_ECHO=false

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# ── JWT Auth ───────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change_me_to_another_random_64_char_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── OpenSearch ─────────────────────────────────────────────────────────────
OPENSEARCH_URL=http://localhost:9200
# OPENSEARCH_USERNAME=admin
# OPENSEARCH_PASSWORD=admin
OPENSEARCH_INDEX_LAWS=eccrp_laws
OPENSEARCH_INDEX_JUDGMENTS=eccrp_judgments
OPENSEARCH_INDEX_KNOWLEDGE=eccrp_knowledge

# ── Neo4j ──────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j_secret

# ── MinIO ──────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_AFFIDAVITS=eccrp-affidavits
MINIO_BUCKET_DOCUMENTS=eccrp-documents
MINIO_SECURE=false

# ── AI / LLM (Required for AI features) ───────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
# For Azure OpenAI or compatible APIs:
# OPENAI_BASE_URL=https://your-instance.openai.azure.com/
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
LLM_TEMPERATURE=0.1
RAG_TOP_K=10
RAG_SIMILARITY_THRESHOLD=0.7

# ── Security ────────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120
ALLOWED_HOSTS=["*"]
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
BCRYPT_ROUNDS=12

# ── File Upload ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10

# ── Celery ─────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Email (Optional) ────────────────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your@email.com
# SMTP_PASSWORD=your-app-password
# FROM_EMAIL=noreply@eccrp.in
